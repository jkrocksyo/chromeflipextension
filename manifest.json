{
  "name": "Google Meet Video Transformer",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Flip, rotate, and reset videos on Google Meet.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "VideoTransformIcon.png",
      "48": "VideoTransformIcon.png",
      "128": "VideoTransformIcon.png"
    }
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://meet.google.com/*"]
}